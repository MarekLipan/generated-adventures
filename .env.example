# Google Gemini API Key (required for text generation, optional for image generation)
GOOGLE_API_KEY=your_google_api_key_here

# Image Generation Backend
# Options:
#   - gemini: Cloud-based, supports reference images (costs per image)
#   - flux: Local FLUX.1 model, high quality (no reference images)
#   - sdxl: Local SDXL model, good quality (no reference images)
#   - sdxl-ip-adapter: Local SDXL + IP-Adapter, supports reference images (FREE!)
IMAGE_PROVIDER=gemini

# Local Image Generation Settings (for FLUX/SDXL)
# ================================================

# FLUX Model Selection
# - black-forest-labs/FLUX.1-dev: Best quality (~15GB, requires GPU)
# - black-forest-labs/FLUX.1-schnell: Faster, lower quality (~15GB)
FLUX_MODEL=black-forest-labs/FLUX.1-dev

# Stable Diffusion XL Model
SDXL_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# IP-Adapter Settings (for sdxl-ip-adapter backend)
# Scale: 0.0-1.0 (higher = more closely follow reference images)
# Recommended: 0.5-0.7 for good balance between prompt and references
IP_ADAPTER_SCALE=0.6

# Device Configuration
# Options: auto (recommended), mps (Mac), cuda (NVIDIA), cpu (slow)
IMAGE_DEVICE=auto

# Generation Quality Settings
# Inference steps: 20-50 (lower=faster, higher=better quality)
IMAGE_NUM_INFERENCE_STEPS=30

# Guidance scale: 7.0-15.0 (how closely to follow prompt)
IMAGE_GUIDANCE_SCALE=7.5

# Optional: Show DM notes during gameplay
# SHOW_DM_NOTES=1
