# Hugging Face Access Token (required for FLUX.1-Kontext-dev, which is gated)
# Get yours at https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here

# Google Gemini API Key (required when IMAGE_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Image Generation Backend: flux-kontext (local, free) or gemini (cloud)
IMAGE_PROVIDER=flux-kontext

# FLUX Kontext model from Hugging Face
FLUX_KONTEXT_MODEL=black-forest-labs/FLUX.1-Kontext-dev

# Device: auto (recommended), cuda, mps, cpu
IMAGE_DEVICE=auto

# Inference steps: lower=faster, higher=better quality
IMAGE_NUM_INFERENCE_STEPS=30

# --- Optional: GGUF pre-quantized models (recommended for limited VRAM) ---
# Format: "repo_id:filename"
# Transformer Q8_0 (~12.7 GB) + T5 Q5_K_M (~3.4 GB) = ~16 GB total
# FLUX_KONTEXT_GGUF_TRANSFORMER=city96/FLUX.1-Kontext-dev-gguf:flux1-kontext-dev-Q8_0.gguf
# FLUX_KONTEXT_GGUF_T5=city96/t5-v1_1-xxl-encoder-gguf:t5-v1_1-xxl-encoder-Q5_K_M.gguf

# --- Optional: Runtime quantization (used only when GGUF is not set) ---
# Options: none (bfloat16, ~24 GB), int8 (~12 GB), int4 (~6 GB)
# IMAGE_QUANTIZATION=int8
